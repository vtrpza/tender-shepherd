---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { MODULES } from '../../lib/modules';
import Stripe from 'stripe';

const period = Number(Astro.url.searchParams.get('period')) || 30;
const validPeriods = [7, 30, 90, 0];
const activePeriod = validPeriods.includes(period) ? period : 30;

const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);

interface DayRevenue {
  date: string;
  amount: number;
}

let charges: Stripe.Charge[] = [];
let totalRevenue = 0;
let refundTotal = 0;
let dailyRevenue: DayRevenue[] = [];
let moduleRevenue: Record<string, number> = {};
let refunds: Stripe.Charge[] = [];

try {
  const params: Stripe.ChargeListParams = { limit: 100 };
  if (activePeriod > 0) {
    const since = new Date();
    since.setDate(since.getDate() - activePeriod);
    params.created = { gte: Math.floor(since.getTime() / 1000) };
  }

  const result = await stripe.charges.list(params);
  charges = result.data;

  const paidCharges = charges.filter((c) => c.paid);
  refunds = paidCharges.filter((c) => c.refunded);
  refundTotal = refunds.reduce((sum, c) => sum + c.amount_refunded, 0) / 100;
  totalRevenue = paidCharges
    .reduce((sum, c) => sum + c.amount - c.amount_refunded, 0) / 100;

  // Group by day
  const dayMap: Record<string, number> = {};
  for (const c of paidCharges) {
    const day = new Date(c.created * 1000).toISOString().slice(0, 10);
    dayMap[day] = (dayMap[day] || 0) + (c.amount - c.amount_refunded) / 100;
  }
  dailyRevenue = Object.entries(dayMap)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([date, amount]) => ({ date, amount }));

  // Revenue by module — from checkout session metadata
  for (const c of paidCharges) {
    if (c.payment_intent) {
      try {
        const pi = await stripe.paymentIntents.retrieve(c.payment_intent as string, {
          expand: ['latest_charge'],
        });
        const session = (await stripe.checkout.sessions.list({
          payment_intent: pi.id,
          limit: 1,
        })).data[0];
        if (session?.metadata?.module_slug) {
          const slug = session.metadata.module_slug;
          const net = (c.amount - c.amount_refunded) / 100;
          moduleRevenue[slug] = (moduleRevenue[slug] || 0) + net;
        }
      } catch {
        /* skip if session lookup fails */
      }
    }
  }
} catch {
  /* Stripe unavailable */
}

const maxDaily = Math.max(...dailyRevenue.map((d) => d.amount), 1);

function formatDay(dateStr: string): string {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
}

function moduleName(slug: string): string {
  if (slug === 'bundle') return 'Pacote completo';
  const mod = MODULES[slug as keyof typeof MODULES];
  return mod ? mod.name : slug;
}
---

<AdminLayout title="Receita — Admin">
  <section class="revenue-page">
    <div class="page-header">
      <div>
        <p class="label">Financeiro</p>
        <h1>Receita</h1>
      </div>
    </div>

    <nav class="period-nav">
      {validPeriods.map((p) => (
        <a
          href={`/admin/revenue?period=${p}`}
          class={`period-btn ${activePeriod === p ? 'active' : ''}`}
        >
          {p === 0 ? 'Tudo' : `${p}d`}
        </a>
      ))}
    </nav>

    <div class="stats-row">
      <div class="stat-card">
        <span class="stat-label">Receita líquida</span>
        <span class="stat-value accent mono">R${totalRevenue.toLocaleString('pt-BR')}</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Transações</span>
        <span class="stat-value mono">{charges.filter((c) => c.paid).length}</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Reembolsos</span>
        <span class="stat-value mono" style="color: var(--red)">R${refundTotal.toLocaleString('pt-BR')}</span>
      </div>
    </div>

    {dailyRevenue.length > 0 && (
      <>
        <h2 class="section-title">Receita por dia</h2>
        <div class="chart">
          {dailyRevenue.map((d) => (
            <div class="chart-col">
              <span class="chart-amount mono">R${d.amount.toFixed(0)}</span>
              <div class="chart-bar" style={`height: ${Math.max((d.amount / maxDaily) * 100, 4)}%`}></div>
              <span class="chart-label mono">{formatDay(d.date)}</span>
            </div>
          ))}
        </div>
      </>
    )}

    {Object.keys(moduleRevenue).length > 0 && (
      <>
        <h2 class="section-title">Receita por módulo</h2>
        <div class="module-revenue-grid">
          {Object.entries(moduleRevenue)
            .sort(([, a], [, b]) => b - a)
            .map(([slug, amount]) => (
              <div class="module-rev-card">
                <span class="module-rev-name">{moduleName(slug)}</span>
                <span class="module-rev-amount mono accent">R${amount.toLocaleString('pt-BR')}</span>
              </div>
            ))}
        </div>
      </>
    )}

    {refunds.length > 0 && (
      <>
        <h2 class="section-title">Reembolsos</h2>
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Data</th>
                <th>Valor reembolsado</th>
                <th>ID</th>
              </tr>
            </thead>
            <tbody>
              {refunds.map((c) => (
                <tr>
                  <td class="mono">{new Date(c.created * 1000).toLocaleDateString('pt-BR')}</td>
                  <td class="mono" style="color: var(--red)">R${(c.amount_refunded / 100).toFixed(2)}</td>
                  <td class="mono text-muted">{c.id}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}
  </section>
</AdminLayout>

<style>
  .page-header {
    margin-bottom: 24px;
  }
  .page-header h1 {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -1px;
    margin-top: 12px;
  }
  .period-nav {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
  }
  .period-btn {
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: var(--radius-badge);
    text-decoration: none;
    color: var(--text-muted);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .period-btn:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
  }
  .period-btn.active {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
  }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .stat-label {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .stat-value {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .stat-value.accent {
    color: var(--accent);
  }
  .section-title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 20px;
  }
  .chart {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 200px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 24px 16px 40px;
    margin-bottom: 48px;
    overflow-x: auto;
  }
  .chart-col {
    flex: 1;
    min-width: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    height: 100%;
    justify-content: flex-end;
  }
  .chart-amount {
    font-size: 10px;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .chart-bar {
    width: 100%;
    max-width: 32px;
    background: var(--accent);
    border-radius: 4px 4px 0 0;
    min-height: 4px;
    transition: height 0.4s ease;
  }
  .chart-label {
    font-size: 10px;
    color: var(--text-muted);
    position: absolute;
    bottom: 12px;
    white-space: nowrap;
  }
  .chart-col {
    position: relative;
    padding-bottom: 20px;
  }
  .module-revenue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }
  .module-rev-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .module-rev-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .module-rev-amount {
    font-size: 18px;
    font-weight: 700;
  }
  .accent {
    color: var(--accent);
  }
  .table-wrap {
    overflow-x: auto;
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .admin-table th {
    text-align: left;
    padding: 12px 16px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .admin-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .admin-table tbody tr:hover {
    background: var(--bg-elevated);
  }
  .text-muted {
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }
</style>
