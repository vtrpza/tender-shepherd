---
---
<header class="topbar" id="topbar">
  <div class="topbar-inner container-lg">
    <a href="/" class="topbar-logo">
      <div class="wordmark">
        <span class="wordmark-top">EMPRESA</span>
        <span class="wordmark-bottom">AUTÔNOMA</span>
      </div>
    </a>
    <span class="topbar-vagas" id="topbar-vagas" style="display:none">
      <span data-vagas></span> vagas restantes
    </span>
    <a href="/curso" class="btn btn-primary topbar-cta">
      Montar Meu Agente — R$97 →
    </a>
  </div>
</header>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .topbar.scrolled {
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(20px) saturate(120%);
    border-bottom-color: var(--border);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
  }
  .topbar-logo {
    text-decoration: none;
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .wordmark-top {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    text-transform: uppercase;
  }
  .wordmark-bottom {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.05em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .topbar-vagas {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
  }
  .topbar-cta { padding: 10px 20px; font-size: 14px; }
  @media (max-width: 640px) {
    .topbar-vagas { display: none !important; }
    .topbar-cta { font-size: 13px; padding: 10px 14px; }
  }
</style>

<script>
  const topbar = document.getElementById('topbar');
  const topbarVagas = document.getElementById('topbar-vagas');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      topbar?.classList.add('scrolled');
      if (topbarVagas) topbarVagas.style.display = 'block';
    } else {
      topbar?.classList.remove('scrolled');
      if (topbarVagas) topbarVagas.style.display = 'none';
    }
  });
</script>
