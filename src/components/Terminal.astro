---
export interface TerminalLine {
  text: string;
  color?: 'default' | 'accent' | 'green' | 'red' | 'amber' | 'muted';
  delay: number; // ms from animation start
  cursor?: boolean;
}

interface Props {
  title: string;
  lines: TerminalLine[];
  autoplay?: boolean;  // true = animate on load; false = animate on viewport entry
  id?: string;
}

const { title, lines, autoplay = false, id = `terminal-${Math.random().toString(36).slice(2,8)}` } = Astro.props;
---

<div class="terminal" id={id} data-autoplay={autoplay}>
  <!-- macOS dots bar -->
  <div class="terminal-bar">
    <div class="terminal-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <span class="terminal-title">{title}</span>
  </div>
  <!-- Output area -->
  <div class="terminal-body">
    {lines.map((line) => (
      <div
        class={`terminal-line tl-${line.color ?? 'default'}`}
        data-delay={line.delay}
        data-cursor={line.cursor ?? false}
        style="opacity:0"
      >
        <span set:html={line.text.replace(/\n/g, '<br/>')} />
        {line.cursor && <span class="cursor">█</span>}
      </div>
    ))}
  </div>
</div>

<style>
  .terminal {
    background: #111113;
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
    overflow: hidden;
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #0d0d0f;
    border-bottom: 1px solid var(--border);
  }
  .terminal-dots { display: flex; gap: 6px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }
  .terminal-title { color: var(--text-muted); font-size: 12px; flex: 1; text-align: center; }
  .terminal-body { padding: 20px 24px; display: flex; flex-direction: column; gap: 6px; line-height: 1.7; }
  .tl-default { color: var(--text-secondary); }
  .tl-accent  { color: var(--accent); }
  .tl-green   { color: var(--green); }
  .tl-red     { color: var(--red); }
  .tl-amber   { color: var(--amber); font-weight: 700; }
  .tl-muted   { color: var(--text-muted); }
  .terminal-line.visible {
    opacity: 1;
    animation: fade-in-up 0.4s ease forwards;
  }
  .cursor {
    display: inline-block;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
    color: var(--accent);
  }
  @media (max-width: 640px) {
    .terminal { font-size: 12px; }
    .terminal-body { padding: 16px; }
  }
</style>

<script>
  function animateTerminal(terminalEl: Element) {
    const lines = terminalEl.querySelectorAll('.terminal-line');
    lines.forEach((line) => {
      const delay = Number((line as HTMLElement).dataset.delay ?? 0);
      setTimeout(() => {
        (line as HTMLElement).classList.add('visible');
      }, delay);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Autoplay terminals
    document.querySelectorAll('.terminal[data-autoplay="true"]').forEach(animateTerminal);

    // Viewport-triggered terminals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateTerminal(entry.target);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    document.querySelectorAll('.terminal[data-autoplay="false"]').forEach((el) => {
      observer.observe(el);
    });
  });
</script>
