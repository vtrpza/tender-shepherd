---
import { UserButton } from '@clerk/astro/components';
---

<header class="admin-topbar">
  <div class="admin-topbar-inner container-lg">
    <a href="/admin" class="admin-topbar-logo">
      <div class="wordmark">
        <span class="wordmark-top">EMPRESA</span>
        <span class="wordmark-bottom">AUTÔNOMA</span>
      </div>
      <span class="admin-badge">ADMIN</span>
    </a>
    <nav class="admin-topbar-nav">
      <a href="/admin" class="admin-topbar-link">Dashboard</a>
      <a href="/admin/users" class="admin-topbar-link">Usuários</a>
      <a href="/admin/revenue" class="admin-topbar-link">Receita</a>
      <a href="/admin/modules" class="admin-topbar-link">Módulos</a>
      <span class="admin-topbar-divider"></span>
      <a href="/curso" class="admin-topbar-link back-link">← Curso</a>
      <UserButton />
    </nav>
  </div>
</header>

<style>
  .admin-topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(9, 9, 11, 0.92);
    backdrop-filter: blur(20px) saturate(120%);
    border-bottom: 1px solid var(--border);
  }
  .admin-topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .admin-topbar-logo {
    text-decoration: none;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .wordmark-top {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 4px;
    color: var(--accent);
  }
  .wordmark-bottom {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }
  .admin-badge {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--red);
    background: rgba(239, 68, 68, 0.12);
    padding: 3px 8px;
    border-radius: var(--radius-badge);
    border: 1px solid rgba(239, 68, 68, 0.25);
  }
  .admin-topbar-nav {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .admin-topbar-link {
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .admin-topbar-link:hover {
    color: var(--text-primary);
  }
  .admin-topbar-divider {
    width: 1px;
    height: 20px;
    background: var(--border);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .admin-topbar-nav {
      gap: 12px;
    }
    .admin-topbar-link {
      font-size: 12px;
    }
  }
</style>
