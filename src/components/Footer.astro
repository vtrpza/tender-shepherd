  .footer-logo { font-size: 14px; color: var(--text-secondary); }
  .footer-tagline { font-size: 13px; color: var(--text-muted); }
  .footer-links { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; font-size: 13px; }
