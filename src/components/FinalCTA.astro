---
---
<section class="final-cta section">
  <div class="container">
    <div class="final-cta-inner reveal">
      <p class="final-loss">
        Cada semana que você espera, seu agente não está pausando as campanhas ruins.<br/>
        Não está fazendo follow-up dos leads. Não está encontrando as cobranças duplicadas.<br/>
        <br/>
        São R$7.500 em equipe que não performa. Mais o budget queimado. Mais os leads que fecharam com o concorrente.
      </p>

      <h2>100 vagas. Preço de fundador.<br/>Depois, volta ao preço cheio.</h2>
      <p>Quando as 100 vagas acabarem, o preço sobe para R$147/módulo e R$297/pacote.<br/>Sem exceção. Sem "me manda DM que eu libero".</p>

      <!-- Vaga counter -->
      <div class="final-vagas">
        <div class="progress-bar-wrap">
          <div class="progress-bar" id="final-progress"></div>
        </div>
        <p class="final-vagas-count">Restam <strong data-vagas>27</strong> vagas</p>
      </div>

      <!-- Main CTA -->
      <a href="/curso" class="btn btn-primary final-btn">
        Montar Os 3 Agentes — R$197 →
      </a>

      <!-- Individual options -->
      <div class="final-individuals">
        <a href="/curso" class="btn btn-ghost">Módulo 01 — R$97</a>
        <a href="/curso" class="btn btn-ghost">Módulo 02 — R$97</a>
        <a href="/curso" class="btn btn-ghost">Módulo 03 — R$97</a>
      </div>

      <!-- Trust badges repeat -->
      <div class="final-trust">
        <span>🔒 Garantia de 7 dias</span>
        <span>📱 Acesso vitalício</span>
        <span>💳 Pagamento único</span>
      </div>
    </div>

    <!-- Email fallback -->
    <div class="email-fallback reveal">
      <p class="email-lead">Quer o guia gratuito?</p>
      <p>Deixe seu email e receba o e-book <strong>Como Automatizar Sua Empresa com Agentes de IA</strong> direto na sua caixa de entrada.</p>
      <form class="email-form" id="email-form" novalidate>
        <input type="email" placeholder="seu@email.com" required class="email-input" />
        <button type="submit" class="btn btn-secondary">E-book gratuito →</button>
      </form>
      <p class="email-success" id="email-success" style="display:none">✓ E-book enviado! <a href="/ebook">Clique aqui para ler agora →</a></p>
    </div>
  </div>
</section>

<style>
  .final-cta { text-align: center; }
  .final-cta-inner { margin-bottom: 80px; }
  .final-loss { font-size: 16px; color: var(--text-secondary); line-height: 1.8; margin-bottom: 48px; max-width: 600px; margin-left: auto; margin-right: auto; }
  .final-cta-inner h2 { margin-bottom: 16px; }
  .final-cta-inner > p { margin-bottom: 40px; }
  .final-vagas { margin-bottom: 40px; }
  .progress-bar-wrap { background: var(--bg-card); border-radius: 100px; height: 8px; overflow: hidden; margin-bottom: 12px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .progress-bar { height: 100%; background: var(--accent); border-radius: 100px; width: 0%; transition: width 1s ease; }
  .final-vagas-count { font-size: 16px; color: var(--text-secondary); }
  .final-btn { font-size: 18px; padding: 20px 56px; margin-bottom: 24px; box-shadow: 0 8px 32px var(--accent-glow); }
  .final-individuals { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 32px; }
  .final-trust { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: var(--text-muted); }

  .email-fallback { max-width: 500px; margin: 0 auto; padding: 48px 32px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-card); }
  .email-lead { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
  .email-fallback > p { margin-bottom: 24px; }
  .email-form { display: flex; gap: 12px; flex-wrap: wrap; }
  .email-input {
    flex: 1; min-width: 200px;
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-button);
    color: var(--text-primary);
    font-size: 15px;
    outline: none;
  }
  .email-input:focus { border-color: var(--accent); }
  .email-success { color: var(--green); font-size: 15px; margin-top: 16px; }
  @media (max-width: 640px) {
    .final-individuals { flex-direction: column; align-items: stretch; }
    .email-form { flex-direction: column; }
    .btn-secondary { width: 100%; justify-content: center; }
  }
</style>

<script>
  const form = document.getElementById('email-form') as HTMLFormElement;
  const success = document.getElementById('email-success') as HTMLElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    if (input?.value?.includes('@')) {
      form.style.display = 'none';
      success.style.display = 'block';
    } else {
      input?.focus();
    }
  });

  const finalProgress = document.getElementById('final-progress') as HTMLElement;
  if (finalProgress) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const vagas = Number(localStorage.getItem('vagas_restantes') ?? 27);
          finalProgress.style.width = `${100 - vagas}%`;
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(finalProgress);
  }
</script>
